{
  "version": "1.0.2",
  "project": {
    "name": "",
    "language": "python"
  },
  "output": {
    "path": "./.memddc/docs",
    "formats": ["markdown"]
  },
  "scanner": {
    "include_patterns": ["*.py"],
    "exclude_patterns": ["__pycache__", "*.pyc", "venv", ".venv", "env", "tests"],
    "max_depth": 10
  },
  "generator": {
    "templates": {
      "standard": {
        "includes": ["architecture", "api", "module-tree", "dependencies"]
      },
      "minimal": {
        "includes": ["architecture"]
      },
      "full": {
        "includes": ["architecture", "api", "module-tree", "dependencies", "er-diagram"]
      }
    },
    "default_template": "standard"
  }
}
